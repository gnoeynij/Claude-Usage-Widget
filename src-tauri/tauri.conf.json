{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Widget",
  "version": "2.4.3",
  "identifier": "com.gnoeynij.claude-widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Widget",
        "width": 320,
        "height": 360,
        "minWidth": 240,
        "minHeight": 112,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "maximizable": false,
        "center": false,
        "skipTaskbar": false,
        "fullscreen": false,
        "alwaysOnTop": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "copyright": "Copyright (c) 2026 gnoeynij",
    "shortDescription": "Claude usage at a glance",
    "longDescription": "A live widget showing Claude usage limits and detailed local statistics, with a Liquid Glass design.",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gnoeynij/Claude-Usage-Widget/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3RDI5NTE4MDkxNzQ4QjYKUldTMlNCY0pHSlhTOS9sZVpzSTFqM29YeldEdS81Q0RxNVdJN2Y5N0VoZC81dTFSQXUrZG1HTFoK"
    }
  }
}
